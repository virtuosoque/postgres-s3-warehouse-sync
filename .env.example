# Source PostgreSQL (use a read replica DSN for extracts)
PG_REPLICA_DSN=postgresql://pipeline:CHANGEME@replica.example.com:5432/appdb?sslmode=require
PG_PRIMARY_DSN=postgresql://pipeline:CHANGEME@primary.example.com:5432/appdb?sslmode=require

# Metadata PostgreSQL: stores Iceberg catalog + pipeline watermarks/chunk state.
# Can be the same instance as source (use a separate schema), or a small dedicated PG
# running in a Docker container on the same EC2.
METADATA_PG_DSN=postgresql://pipeline:pipeline@metadata-postgres:5432/pipeline_metadata
METADATA_PG_SCHEMA=pipeline

# AWS
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000

# S3 buckets (created by Terraform). SSE-S3 (AES256) is used; no KMS required.
RAW_BUCKET=viamedia-lake-raw
CURATED_BUCKET=viamedia-lake-curated
GATEWAY_RESULTS_BUCKET=viamedia-lake-gateway-results
ICEBERG_WAREHOUSE_S3=s3://viamedia-lake-curated/

# Iceberg catalog (PyIceberg SqlCatalog backed by METADATA_PG_DSN)
ICEBERG_CATALOG_NAME=pg
ICEBERG_NAMESPACE=viamedia_lake

# Sync selection -----------------------------------------------------------
# Comma-separated glob patterns matched against "schema.name".
# Empty SYNC_INCLUDE  = sync everything discovered.
# Empty SYNC_EXCLUDE  = exclude nothing.
# Exclude is applied after include.
# Examples:
#   SYNC_INCLUDE=public.*,analytics.events_*
#   SYNC_EXCLUDE=public.audit_log,*.temp_*,public._archive_*
SYNC_INCLUDE=
SYNC_EXCLUDE=
# Object kinds to consider. Subset of: TABLE,VIEW,MATERIALIZED_VIEW
SYNC_OBJECT_TYPES=TABLE,VIEW,MATERIALIZED_VIEW
# Schemas to never scan.
SYNC_SCHEMA_BLACKLIST=pg_catalog,information_schema,pg_toast

# Extractor tuning
EXTRACT_ROWS_PER_CHUNK=5000000
EXTRACT_ROW_GROUP_ROWS=500000
PARQUET_COMPRESSION=zstd
PARQUET_COMPRESSION_LEVEL=3

# Incremental tuning
INCREMENTAL_OVERLAP_SECONDS=300
INCREMENTAL_SAFETY_GAP_SECONDS=30

# Gateway
GATEWAY_JWT_AUDIENCE=viamedia-gateway
GATEWAY_JWT_ISSUER=https://your-idp.example.com
GATEWAY_JWKS_URL=https://your-idp.example.com/.well-known/jwks.json
GATEWAY_MAX_BYTES_SCANNED=10737418240
GATEWAY_QUERY_TIMEOUT_SECONDS=120
GATEWAY_ALLOWED_SCHEMAS=viamedia_lake
GATEWAY_VIEW_REFRESH_SECONDS=60

# Observability
LOG_LEVEL=INFO
