# Template for running locally against REAL AWS RDS + REAL AWS S3.
#   cp .env.localaws.example .env.localaws   and fill in every <...>.
# .env.localaws holds real secrets -- it is gitignored; never commit it.
#
# NOTE: configuration is now managed in the web UI (http://localhost:3000 ->
# Connections / Sync / Settings), stored in the metadata DB. The only values
# that MUST stay here are the bootstrap ones: METADATA_PG_DSN, METADATA_PG_SCHEMA,
# CONFIG_ENCRYPTION_KEY, LOG_LEVEL. The PG_REPLICA_DSN / AWS / bucket / SYNC_*
# values below are used ONCE to seed a "default" connection on first boot (so an
# existing single-DB setup keeps working); after that, manage everything in the UI.

# ============================================================
# SOURCE: your AWS RDS Postgres (use the READ REPLICA endpoint)
# ============================================================
# Your Mac must be able to reach this host (see "RDS reachability" notes).
PG_REPLICA_DSN=postgresql://<USER>:<PASSWORD>@<replica-endpoint>.<id>.<region>.rds.amazonaws.com:5432/<DBNAME>?sslmode=require

# ============================================================
# METADATA: local container -- Iceberg catalog + watermarks + chunk state.
# Leave as-is; this is the metadata-postgres service in the compose file.
# (It must be writable, so it is NOT your read replica.)
# ============================================================
METADATA_PG_DSN=postgresql://pipeline:pipeline@metadata-postgres:5432/pipeline_metadata
METADATA_PG_SCHEMA=pipeline

# ============================================================
# TARGET: real AWS S3 + credentials
# ============================================================
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=<your-12-digit-account-id>

# Credentials for an IAM user/role with S3 access to the buckets below.
# (On EC2 you'd drop these and use the instance role instead.)
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
# AWS_SESSION_TOKEN=<only if using temporary STS credentials>

# Buckets must ALREADY EXIST in your account/region (the pipeline does not
# create them). Names must be globally unique.
RAW_BUCKET=<your-raw-bucket>
CURATED_BUCKET=<your-curated-bucket>
GATEWAY_RESULTS_BUCKET=<your-gateway-results-bucket>
ICEBERG_WAREHOUSE_S3=s3://<your-curated-bucket>/

ICEBERG_CATALOG_NAME=pg
ICEBERG_NAMESPACE=viamedia_lake

# ============================================================
# What to sync -- start with ONE table to validate end-to-end.
# Must have an integer `id` + `updated_at` to exercise chunking + incremental.
# ============================================================
SYNC_INCLUDE=public.<your_table>
SYNC_EXCLUDE=
SYNC_OBJECT_TYPES=TABLE,VIEW,MATERIALIZED_VIEW
SYNC_SCHEMA_BLACKLIST=pg_catalog,information_schema,pg_toast

# Extractor tuning (defaults are fine for a first test)
EXTRACT_ROWS_PER_CHUNK=5000000
EXTRACT_ROW_GROUP_ROWS=500000
PARQUET_COMPRESSION=zstd
PARQUET_COMPRESSION_LEVEL=3

INCREMENTAL_OVERLAP_SECONDS=300
INCREMENTAL_SAFETY_GAP_SECONDS=30

# ============================================================
# Gateway (auth disabled locally: empty issuer/jwks => no JWT required)
# ============================================================
GATEWAY_JWT_ISSUER=
GATEWAY_JWKS_URL=
GATEWAY_ALLOWED_SCHEMAS=viamedia_lake
GATEWAY_VIEW_REFRESH_SECONDS=30

LOG_LEVEL=INFO

# ============================================================
# Bootstrap secret: Fernet key used to encrypt UI-managed connection
# credentials (source DSNs, AWS keys) at rest in the metadata DB.
# Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   (or: head -c 32 /dev/urandom | base64 | tr '+/' '-_')
# Keep it safe and stable; changing it makes stored secrets undecryptable.
# ============================================================
CONFIG_ENCRYPTION_KEY=<your-fernet-key>
