# Local development settings consumed by docker-compose.dev.yml services.
# Do not put real secrets here.

PG_REPLICA_DSN=postgresql://pipeline:pipeline@postgres:5432/appdb
METADATA_PG_DSN=postgresql://pipeline:pipeline@metadata-postgres:5432/pipeline_metadata
METADATA_PG_SCHEMA=pipeline

AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000

RAW_BUCKET=viamedia-lake-raw
CURATED_BUCKET=viamedia-lake-curated
GATEWAY_RESULTS_BUCKET=viamedia-lake-gateway-results
ICEBERG_WAREHOUSE_S3=s3://viamedia-lake-curated/
ICEBERG_CATALOG_NAME=pg
ICEBERG_NAMESPACE=viamedia_lake

GATEWAY_JWT_AUDIENCE=viamedia-gateway
GATEWAY_JWT_ISSUER=
GATEWAY_JWKS_URL=
GATEWAY_ALLOWED_SCHEMAS=viamedia_lake
GATEWAY_VIEW_REFRESH_SECONDS=15

SYNC_INCLUDE=public.events

LOG_LEVEL=DEBUG
